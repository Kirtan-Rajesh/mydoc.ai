# mydoc.ai backend environment
# Copy to backend/.env — EVERY value below is optional in development:
# with no .env at all, the backend runs on SQLite + local storage + offline
# echo LLM and prints OTPs to the console.

# ---- App ----
ENVIRONMENT=development            # development | staging | production
DEBUG=true

# ---- Database ----
# dev default: sqlite+aiosqlite:///./mydoc.db
# production:  postgresql+asyncpg://USER:PASSWORD@HOST:5432/mydoc
#DATABASE_URL=postgresql+asyncpg://mydoc:password@localhost:5432/mydoc

# ---- Auth ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
#SECRET_KEY=change-me-in-production

# ---- SMS (OTP delivery) ----
# console (dev: OTP logged + returned in response) | msg91 | twilio
SMS_PROVIDER=console
#MSG91_AUTH_KEY=
#MSG91_TEMPLATE_ID=
#TWILIO_ACCOUNT_SID=
#TWILIO_AUTH_TOKEN=
#TWILIO_PHONE=

# ---- LLM ----
# LLM_PROVIDER=auto picks gemini when GEMINI_API_KEY is set, else offline echo.
# Get a free key: https://aistudio.google.com/apikey
LLM_PROVIDER=auto
#GEMINI_API_KEY=
CHAT_MODEL=gemini-2.0-flash
VISION_MODEL=gemini-2.0-flash
EMBED_MODEL=text-embedding-004

# ---- Storage ----
STORAGE_BACKEND=local              # local | gcs
UPLOAD_DIR=./uploads
#GCS_BUCKET_NAME=mydoc-documents

# ---- Limits ----
FREE_PLAN_DOC_LIMIT=25
FREE_PLAN_DAILY_CHAT_LIMIT=20
RATE_LIMIT_ENABLED=true

# ---- Observability ----
#SENTRY_DSN=
